generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AssessmentRunStatus {
  DRAFT
  IN_PROGRESS
  SUBMITTED
  ARCHIVED
}

enum AssessmentPeriodType {
  QUARTER
  CUSTOM_RANGE
  POINT_IN_TIME
}

enum UserRole {
  ADMIN
  TEMPLATE_MANAGER
  TEAM_LEAD
  TEAM_MEMBER
  VIEWER
}

enum TeamMembershipRole {
  LEAD
  MEMBER
}

model User {
  id               String               @id @default(cuid())
  displayName      String
  username         String               @unique
  email            String?              @unique
  role             UserRole             @default(TEAM_MEMBER)
  isActive         Boolean              @default(true)
  mustChangePassword Boolean            @default(false)
  passwordHash     String
  sessionToken     String?              @unique
  sessionExpiresAt DateTime?
  inviteToken      String?              @unique
  inviteExpiresAt  DateTime?
  lastLoginAt      DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  teamMemberships     UserTeamMembership[]
  ownedRuns           AssessmentRun[]           @relation("AssessmentRunOwner")
  assignmentChanges   AssessmentRunAssignment[] @relation("AssessmentRunAssignedByUser")
  assignmentFromEvents AssessmentRunAssignment[] @relation("AssessmentRunFromUser")
  assignmentToEvents   AssessmentRunAssignment[] @relation("AssessmentRunToUser")
  createdShareLinks    ReportShareLink[]
  createdGuestAssessmentLinks GuestAssessmentLink[]
  auditLogs            AuditLog[]
  notifications        Notification[]
}

model PlatformSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model UserTeamMembership {
  id             String             @id @default(cuid())
  userId         String
  teamId         String
  membershipRole TeamMembershipRole @default(MEMBER)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  team           Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}

model Team {
  id             String          @id @default(cuid())
  name           String          @unique
  description    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  assessmentRuns AssessmentRun[]
  memberships    UserTeamMembership[]
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AssessmentTemplate {
  id             String            @id @default(cuid())
  name           String
  slug           String            @unique
  description    String?
  category       String?
  status         String            @default("ACTIVE")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  versions       TemplateVersion[]
  assessmentRuns AssessmentRun[]
}

model TemplateDraft {
  id            String   @id @default(cuid())
  name          String
  slug          String
  description   String?
  category      String?
  status        String   @default("DRAFT")
  scoringLabels Json
  draftData     Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model QuestionLibraryItem {
  id          String   @id @default(cuid())
  title       String
  prompt      String
  guidance    String?
  levels      Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DomainLibraryItem {
  id          String   @id @default(cuid())
  title       String
  description String?
  questions   Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TemplateVersion {
  id             String             @id @default(cuid())
  versionNumber  Int
  templateId     String
  name           String
  description    String?
  category       String?
  scoringLabels  Json
  createdAt      DateTime           @default(now())
  template       AssessmentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  domains        TemplateDomain[]
  assessmentRuns AssessmentRun[]

  @@unique([templateId, versionNumber])
}

model TemplateDomain {
  id              String            @id @default(cuid())
  versionId       String
  title           String
  description     String?
  sortOrder       Int
  templateVersion TemplateVersion   @relation(fields: [versionId], references: [id], onDelete: Cascade)
  questions       TemplateQuestion[]
}

model TemplateQuestion {
  id             String               @id @default(cuid())
  domainId       String
  prompt         String
  guidance       String?
  sortOrder      Int
  templateDomain TemplateDomain       @relation(fields: [domainId], references: [id], onDelete: Cascade)
  levels         QuestionLevel[]
  responses      AssessmentResponse[]
}

model QuestionLevel {
  id          String           @id @default(cuid())
  questionId  String
  value       Int
  label       String
  description String
  sortOrder   Int
  question    TemplateQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model AssessmentRun {
  id                String              @id @default(cuid())
  templateId        String
  templateVersionId String
  teamId            String
  ownerUserId       String?
  title             String
  ownerName         String?
  dueDate           DateTime?
  periodType        AssessmentPeriodType @default(QUARTER)
  periodLabel       String
  periodBucket      String               @default("")
  periodSortDate    DateTime             @default(now())
  year              Int?
  quarter           Int?
  startDate         DateTime?
  endDate           DateTime?
  referenceDate     DateTime?
  status            AssessmentRunStatus @default(DRAFT)
  overallScore      Float?
  submissionSummary String?
  submittedAt       DateTime?
  guestParticipationEnabled Boolean     @default(false)
  guestResultsVisible Boolean          @default(false)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  template          AssessmentTemplate  @relation(fields: [templateId], references: [id])
  templateVersion   TemplateVersion     @relation(fields: [templateVersionId], references: [id])
  team              Team                @relation(fields: [teamId], references: [id])
  ownerUser         User?               @relation("AssessmentRunOwner", fields: [ownerUserId], references: [id])
  responses         AssessmentResponse[]
  assignmentHistory AssessmentRunAssignment[]
  shareLinks        ReportShareLink[]
  guestLinks        GuestAssessmentLink[]
  aiSummaries       AiAssessmentSummary[]
  auditLogs         AuditLog[]
  notifications     Notification[]
}

model AssessmentRunAssignment {
  id                String        @id @default(cuid())
  assessmentRunId   String
  assignedByUserId  String
  fromUserId        String?
  toUserId          String?
  fromOwnerName     String?
  toOwnerName       String?
  createdAt         DateTime      @default(now())
  assessmentRun     AssessmentRun @relation(fields: [assessmentRunId], references: [id], onDelete: Cascade)
  assignedByUser    User          @relation("AssessmentRunAssignedByUser", fields: [assignedByUserId], references: [id])
  fromUser          User?         @relation("AssessmentRunFromUser", fields: [fromUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  toUser            User?         @relation("AssessmentRunToUser", fields: [toUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
}

model AssessmentResponse {
  id              String           @id @default(cuid())
  assessmentRunId String
  questionId      String
  selectedValue   Int
  selectedLabel   String
  comment         String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  assessmentRun   AssessmentRun    @relation(fields: [assessmentRunId], references: [id], onDelete: Cascade)
  question        TemplateQuestion @relation(fields: [questionId], references: [id])

  @@unique([assessmentRunId, questionId])
}

model ReportShareLink {
  id              String        @id @default(cuid())
  token           String        @unique
  assessmentRunId String
  createdByUserId String
  isRevoked       Boolean       @default(false)
  expiresAt       DateTime?
  createdAt       DateTime      @default(now())
  assessmentRun   AssessmentRun @relation(fields: [assessmentRunId], references: [id], onDelete: Cascade)
  createdByUser   User          @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
}

model GuestAssessmentLink {
  id                String        @id @default(cuid())
  token             String        @unique
  assessmentRunId   String
  createdByUserId   String
  inviteLabel       String?
  guestDisplayName  String?
  guestEmail        String?
  isRevoked         Boolean       @default(false)
  expiresAt         DateTime?
  startedAt         DateTime?
  lastAccessedAt    DateTime?
  submittedAt       DateTime?
  createdAt         DateTime      @default(now())
  assessmentRun     AssessmentRun @relation(fields: [assessmentRunId], references: [id], onDelete: Cascade)
  createdByUser     User          @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id              String        @id @default(cuid())
  actorUserId     String?
  assessmentRunId String?
  entityType      String
  entityId        String
  action          String
  summary         String
  metadata        Json?
  createdAt       DateTime      @default(now())
  actorUser       User?         @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  assessmentRun   AssessmentRun? @relation(fields: [assessmentRunId], references: [id], onDelete: SetNull)
}

model Notification {
  id              String        @id @default(cuid())
  userId          String
  assessmentRunId String?
  type            String
  title           String
  message         String
  linkUrl         String?
  isRead          Boolean       @default(false)
  createdAt       DateTime      @default(now())
  readAt          DateTime?
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessmentRun   AssessmentRun? @relation(fields: [assessmentRunId], references: [id], onDelete: SetNull)
}

model AiAssessmentSummary {
  id                String        @id @default(cuid())
  assessmentRunId   String
  provider          String
  model             String
  compareToRunId    String?
  payload           Json
  generatedByUserId String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  assessmentRun     AssessmentRun @relation(fields: [assessmentRunId], references: [id], onDelete: Cascade)

  @@unique([assessmentRunId, provider, model, compareToRunId])
}

model AiReportsBrief {
  id                String   @id @default(cuid())
  cacheKey          String   @unique
  provider          String
  model             String
  payload           Json
  generatedByUserId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
